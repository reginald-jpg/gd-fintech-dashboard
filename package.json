    "helmet": "^7.1.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prisma": "^6.5.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.22.0",
    "typescript": "^5.7.3",
