NODE_ENV=development
PORT=8080

# Comma-separated list. Leave empty to allow all origins in dev.
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=debug

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Local docker-compose default:
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fintech?schema=public

# Seed defaults (optional)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_TEST_EMAIL=user@example.com
SEED_TEST_PASSWORD=user123

